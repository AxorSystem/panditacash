{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["vite/client", "node"],
    "paths": { "@/*": ["src/*"] },
    "baseUrl": ".",
    "noEmit": true
  },
  "include": ["src/**/*", "src/**/*.vue"]
}
